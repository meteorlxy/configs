{
  "name": "@meteorlxy/configs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "check-rules": "pnpm --filter=eslint-config check-rules",
    "check-types": "tsc --noEmit --skipLibCheck",
    "clean": "pnpm -r run clean",
    "format": "oxfmt",
    "lint": "eslint . && oxfmt --check",
    "prepare": "husky",
    "release": "pnpm release:check && pnpm release:version",
    "release:check": "pnpm clean && pnpm build && pnpm lint && pnpm check-types",
    "release:version": "lerna version"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:dev",
    "@commitlint/config-conventional": "catalog:dev",
    "@commitlint/types": "catalog:dev",
    "@lerna-lite/cli": "catalog:dev",
    "@lerna-lite/publish": "catalog:dev",
    "@meteorlxy/eslint-config": "workspace:*",
    "@meteorlxy/oxfmt-config": "workspace:*",
    "@meteorlxy/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "eslint": "catalog:eslint",
    "husky": "catalog:dev",
    "lint-staged": "catalog:dev",
    "oxfmt": "catalog:oxfmt",
    "rimraf": "catalog:dev",
    "taze": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "lint-staged": {
    "!(test)/**/*.(js|ts)": [
      "eslint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "!(test)/**/*.!(js|ts)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.33.0"
}
